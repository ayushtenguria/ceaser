DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ceaser
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
CLERK_SECRET_KEY=your-clerk-secret-key
CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
ENCRYPTION_KEY=generate-a-fernet-key
CORS_ORIGINS=["http://localhost:5173"]
DEV_MODE=false

# Agent tuning (all optional — defaults shown)
MAX_RETRIES=3
SQL_ROW_LIMIT=1000
SANDBOX_TIMEOUT_SECONDS=30
CELL_TIMEOUT_SECONDS=120
MAX_EXCEL_ROWS=2000000
QUERY_TIMEOUT_SECONDS=60
DEV_FALLBACK_EMAIL=admin@ceaser.local

# LLM models — two tiers for cost optimization
GEMINI_MODEL=gemini-2.5-flash              # Heavy: SQL, Python, analysis, reports
GEMINI_MODEL_LIGHT=gemini-2.0-flash-lite   # Light: router, verifier, suggestions, memory
# When Gemini 3 is available on the API, switch to:
# GEMINI_MODEL=gemini-3-flash
# GEMINI_MODEL_LIGHT=gemini-3.1-flash-lite

# ── Notifications (for scheduled notebooks + reports) ────────────────
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=reports@ceaser.app

# ── Snowflake ────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# ── BigQuery ─────────────────────────────────────────────────────────
BIGQUERY_PROJECT_ID=
BIGQUERY_CREDENTIALS_JSON=   # base64-encoded service account JSON
CLAUDE_MODEL=claude-sonnet-4-20250514      # Optional: user-selectable alternative

# Super admin (comma-separated emails)
SUPER_ADMIN_EMAILS=["ayush.sharma.ug20@nsut.ac.in"]

# ── Storage ──────────────────────────────────────────────────────────────
# "local" (default) stores files in backend/uploads/
# "supabase" stores files in Supabase Storage (zero local disk usage)
STORAGE_BACKEND=local
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_BUCKET=ceaser-files

# ── Payment Gateway ──────────────────────────────────────────────────────
# Set PAYMENT_PROVIDER to enable payments: "stripe", "razorpay", or "cashfree"
PAYMENT_PROVIDER=

# Stripe (international)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MAP=starter:price_xxx,business:price_yyy

# Razorpay (India)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
RAZORPAY_PLAN_MAP=starter:plan_xxx,business:plan_yyy

# Cashfree (India)
CASHFREE_APP_ID=...
CASHFREE_SECRET_KEY=...
CASHFREE_WEBHOOK_SECRET=...
CASHFREE_PLAN_MAP=starter:plan_xxx,business:plan_yyy
CASHFREE_SANDBOX=true
